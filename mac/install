#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$REPO_DIR/shared/lib.sh"

msg "=== Mac Setup ==="

# ============================================
# Homebrew
# ============================================
if ! command -v brew &>/dev/null; then
    msg "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if [[ -f /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -f /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
else
    msg "Homebrew already installed"
fi

msg "Upgrading Homebrew packages..."
brew upgrade

msg "Installing packages from Brewfile..."
brew bundle --file="$SCRIPT_DIR/Brewfile"

# ============================================
# macOS preferences
# ============================================
msg "Configuring macOS appearance and Dock..."

# Dark mode
defaults write NSGlobalDomain AppleInterfaceStyle -string "Dark"

# Automatically hide Dock
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock autohide-delay -float 0
defaults write com.apple.dock autohide-time-modifier -float 0.15

# Minimize windows using scale effect
defaults write com.apple.dock mineffect -string "scale"

# Minimize windows into application icon
defaults write com.apple.dock minimize-to-application -bool true

# Click wallpaper to reveal desktop only in Stage Manager
defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -bool false

# Screenshots
mkdir -p "$HOME/Documents/Screenshots"
defaults write com.apple.screencapture location -string "$HOME/Documents/Screenshots"
defaults write com.apple.screencapture type -string "jpg"

# Dock apps: Finder, Zen, Chrome, Outlook, Slack, VS Code, Ghostty
if command -v dockutil &>/dev/null; then
    dockutil --remove all --no-restart

    DOCK_APPS=(
        "/Applications/Zen.app"
        "/Applications/Helium.app"
        "/Applications/Microsoft Outlook.app"
        "/Applications/Slack.app"
        "/Applications/Visual Studio Code.app"
        "/Applications/Ghostty.app"
    )

    for app_path in "${DOCK_APPS[@]}"; do
        if [[ -d "$app_path" ]]; then
            dockutil --add "$app_path" --no-restart
        else
            msg "Skipping missing app for Dock: $app_path"
        fi
    done

    killall Dock || true
fi

# Set default browser to Zen
if command -v defaultbrowser &>/dev/null; then
    if [[ -d "/Applications/Zen.app" ]]; then
        defaultbrowser zen
    else
        msg "Skipping default browser config: Zen is not installed"
    fi
fi

# ============================================
# Power settings
# ============================================
msg "Configuring power settings..."
sudo pmset -a displaysleep 30

# ============================================
# Show hidden files in Finder
defaults write com.apple.finder AppleShowAllFiles -bool true

# ============================================
# Suppress last login message
# ============================================
touch ~/.hushlogin

# ============================================
# Touch ID for sudo
# ============================================
SUDO_LOCAL="/etc/pam.d/sudo_local"
if ! grep -q "pam_tid.so" "$SUDO_LOCAL" 2>/dev/null; then
    msg "Enabling Touch ID for sudo (requires sudo)..."
    echo "auth       sufficient     pam_tid.so" | sudo tee -a "$SUDO_LOCAL" > /dev/null
fi

# ============================================
# Node.js + pnpm (via corepack)
# ============================================
if ! command -v node &>/dev/null; then
    msg "Installing Node.js LTS via fnm..."
    eval "$(fnm env --shell bash)"
    fnm install --lts --corepack-enabled
    fnm use lts-latest
else
    msg "Node.js already installed"
fi

# ============================================
# Dotfiles (shared)
# ============================================
"$REPO_DIR/dotfiles/install"

msg ""
msg "=== Mac Setup Complete ==="
