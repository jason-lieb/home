{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(pnpm:*)",
      "Bash(which:*)",
      "mcp__ide__getDiagnostics",
      "Skill(update-config)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout .:*)",
      "Bash(git restore .:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(pnpm publish:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "HTTPS_PROXY": "http://127.0.0.1:9009",
    "HTTP_PROXY": "http://127.0.0.1:9009",
    "NODE_TLS_REJECT_UNAUTHORIZED": "0"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; sleep 0.1 && touch \"$f\"; } 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccstatusline@latest"
  }
}
