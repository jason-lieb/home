{
  "model": "sonnet",
  "env": {
    "HTTPS_PROXY": "http://127.0.0.1:9009",
    "HTTP_PROXY": "http://127.0.0.1:9009",
    "NO_PROXY": "localhost,127.0.0.1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "NODE_TLS_REJECT_UNAUTHORIZED": "0"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(pnpm:*)",
      "Bash(which:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh api:*)",
      "mcp__ide__getDiagnostics",
      "Skill(update-config)",
      "Read(~/.claude/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(shred*)",
      "Bash(chmod -R 777 *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(nmap*)",
      "Bash(nc -l*)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(./.env)"
    ],
    "ask": [
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(rm *)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.ssh)",
      "Read(~/.docker/config.json)",
      "Edit(~/.aws)",
      "Edit(~/.ssh)",
      "Edit(~/.gnupg)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zprofile)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr reopen:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh api -X POST:*)",
      "Bash(gh api -X PUT:*)",
      "Bash(gh api -X PATCH:*)",
      "Bash(gh api -X DELETE:*)",
      "Bash(gh api --method POST:*)",
      "Bash(gh api --method PUT:*)",
      "Bash(gh api --method PATCH:*)",
      "Bash(gh api --method DELETE:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git checkout .:*)",
      "Bash(git restore .:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(pnpm publish:*)"
    ],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable"
  },
  "allowManagedHooksOnly": false,
  "allowManagedMcpServersOnly": true,
  "sandbox": {
    "enabled": false,
    "enableWeakerNetworkIsolation": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "git",
      "gh",
      "npm",
      "npx",
      "yarn",
      "pnpm",
      "pip",
      "pip3",
      "poetry",
      "uv",
      "cargo",
      "go",
      "node",
      "python",
      "python3",
      "java",
      "make",
      "cmake",
      "gcc",
      "g++",
      "mvn",
      "gradle",
      "dotnet",
      "docker",
      "docker-compose",
      "aws",
      "terraform",
      "jq",
      "curl",
      "brew",
      "code",
      "open"
    ],
    "network": {
      "allowLocalBinding": true,
      "httpProxyPort": 9009
    },
    "filesystem": {
      "allowManagedReadPathsOnly": false,
      "denyWrite": ["/etc", "/usr", "/System", "/Library"],
      "denyRead": [
        "~/.gnupg",
        "~/.config/gcloud",
        "~/.azure",
        "~/.npmrc",
        "~/.pypirc",
        "/etc/shadow"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; sleep 0.1 && touch \"$f\"; } 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccstatusline@latest",
    "padding": 0
  }
}
