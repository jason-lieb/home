# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

Host github.com
    IgnoreUnknown UseKeychain
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    AddKeysToAgent yes
    UseKeychain yes

Host github.com-work
    IgnoreUnknown UseKeychain
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_work
    AddKeysToAgent yes
    UseKeychain yes
    IdentitiesOnly yes

# IgnoreUnknown prevents errors for configs available only on some systems
# and it must be listed before the erroring config
# IdentitiesOnly is necessary, so it doesn't try to use the other github ssh key
