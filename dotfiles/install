#!/bin/bash
set -euo pipefail

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
msg() { echo -e "${GREEN}$*${NC}"; }
warn() { echo -e "${YELLOW}$*${NC}"; }
ask() {
    local prompt="$1"
    local result
    warn "$prompt [y/N] "
    read -r result
    case "$result" in
        [yY]|[yY][eE][sS]) return 0 ;;
        *) return 1 ;;
    esac
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$SCRIPT_DIR"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

msg "=== Dotfiles Configuration ==="

OS="$(uname -s)"
case "$OS" in
    Linux)
        VSCODE_USER_DIR="$HOME/.config/Code/User"
        FISH_PATH="/usr/bin/fish"
        get_hostname() { hostnamectl hostname 2>/dev/null || cat /etc/hostname; }
        get_current_shell() { echo "$SHELL"; }
        ;;
    Darwin)
        VSCODE_USER_DIR="$HOME/Library/Application Support/Code/User"
        FISH_PATH="/opt/homebrew/bin/fish"
        get_hostname() { scutil --get ComputerName 2>/dev/null || hostname -s; }
        get_current_shell() { dscl . -read ~/ UserShell 2>/dev/null | awk '{print $2}'; }
        ;;
    *)
        msg "ERROR: Unsupported OS: $OS" >&2
        exit 1
        ;;
esac

backup_existing() {
    local path="$1"
    if [[ -e "$path" && ! -L "$path" ]]; then
        local backup_path="${path}.backup"
        if [[ -e "$backup_path" ]]; then
            backup_path="${path}.backup.$(date +%s)"
        fi
        msg "Backing up existing $path to $backup_path"
        mv "$path" "$backup_path"
    fi
}

link() {
    local src="$1"
    local dest="$2"

    if [[ ! -e "$src" ]]; then
        msg "ERROR: Missing source file: $src" >&2
        return 1
    fi

    if [[ -L "$dest" && "$(readlink "$dest")" == "$src" ]]; then
        return 0
    fi

    backup_existing "$dest"

    if [[ -L "$dest" ]]; then
        rm "$dest"
    fi

    msg "Linking $src -> $dest"
    ln -s "$src" "$dest"
}

msg "Creating config directories..."
mkdir -p "$HOME/.claude"
mkdir -p "$HOME/.claude/hooks"
mkdir -p "$HOME/.config/ghostty"
mkdir -p "$HOME/.config/direnv"
mkdir -p "$HOME/.config/gh"
mkdir -p "$HOME/.config/posix"
mkdir -p "$HOME/.config/ccstatusline"
mkdir -p "$HOME/.config/opencode"
mkdir -p "$HOME/.codex"
mkdir -p "$HOME/.ssh"
mkdir -p "$VSCODE_USER_DIR/snippets"

msg "Linking dotfiles..."
link "$DOTFILES_DIR/shells/fish" "$HOME/.config/fish"
link "$DOTFILES_DIR/shells/posix/env.sh" "$HOME/.config/posix/env.sh"
link "$DOTFILES_DIR/shells/posix/functions.sh" "$HOME/.config/posix/functions.sh"
link "$DOTFILES_DIR/shells/posix/aliases.sh" "$HOME/.config/posix/aliases.sh"
link "$DOTFILES_DIR/shells/posix/.bashrc" "$HOME/.bashrc"
link "$DOTFILES_DIR/shells/posix/.zshrc" "$HOME/.zshrc"
link "$DOTFILES_DIR/git/.gitconfig" "$HOME/.gitconfig"
link "$DOTFILES_DIR/git/.gitconfig.cinc" "$HOME/.gitconfig.cinc"
link "$DOTFILES_DIR/git/.gitignore" "$HOME/.gitignore"
link "$DOTFILES_DIR/ghostty/config" "$HOME/.config/ghostty/config"
link "$DOTFILES_DIR/direnv/direnvrc" "$HOME/.config/direnv/direnvrc"
link "$DOTFILES_DIR/gh/config.yml" "$HOME/.config/gh/config.yml"
link "$DOTFILES_DIR/vscode/settings.json" "$VSCODE_USER_DIR/settings.json"
link "$DOTFILES_DIR/.claude/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
link "$DOTFILES_DIR/.claude/skills" "$HOME/.claude/skills"
link "$DOTFILES_DIR/.claude/agents" "$HOME/.claude/agents"
link "$DOTFILES_DIR/.claude/hooks/session-start" "$HOME/.claude/hooks/session-start"
chmod +x "$DOTFILES_DIR/.claude/hooks/session-start"
link "$DOTFILES_DIR/ccstatusline/settings.json" "$HOME/.config/ccstatusline/settings.json"
link "$DOTFILES_DIR/opencode/commands" "$HOME/.config/opencode/commands"
link "$DOTFILES_DIR/codex/config.toml" "$HOME/.codex/config.toml"
for lang in typescript typescriptreact javascript javascriptreact; do
    link "$DOTFILES_DIR/vscode/snippets/typescript.json" "$VSCODE_USER_DIR/snippets/${lang}.json"
done

msg "Configuring Claude Code settings..."
if [[ -f "$HOME/.claude/settings.json" ]]; then
    jq -s '.[0] * .[1]' "$HOME/.claude/settings.json" "$DOTFILES_DIR/.claude/settings.json" > /tmp/claude-settings.json
    mv /tmp/claude-settings.json "$HOME/.claude/settings.json"
else
    cp "$DOTFILES_DIR/.claude/settings.json" "$HOME/.claude/settings.json"
fi

msg "Configuring opencode settings..."
if [[ -f "$HOME/.config/opencode/opencode.json" ]]; then
    jq -s '.[0] * .[1]' "$HOME/.config/opencode/opencode.json" "$DOTFILES_DIR/opencode/opencode.json" > /tmp/opencode-settings.json
    mv /tmp/opencode-settings.json "$HOME/.config/opencode/opencode.json"
else
    cp "$DOTFILES_DIR/opencode/opencode.json" "$HOME/.config/opencode/opencode.json"
fi

if [[ "$OS" == "Darwin" ]]; then
    link "$DOTFILES_DIR/.ssh/mac" "$HOME/.ssh/config"
    link "$DOTFILES_DIR/git/.gitconfig.mac" "$HOME/.gitconfig.local"
else
    link "$DOTFILES_DIR/.ssh/arch" "$HOME/.ssh/config"
fi

# ============================================
# VS Code Extensions
# ============================================
EXTENSIONS_FILE="$DOTFILES_DIR/vscode/extensions.txt"
if [[ -f "$EXTENSIONS_FILE" ]] && command -v code &>/dev/null; then
    msg "Installing VS Code extensions..."
    INSTALLED_EXTENSIONS="$(code --list-extensions 2>/dev/null || true)"
    while IFS= read -r ext; do
        [[ -z "$ext" || "$ext" == \#* ]] && continue
        if ! echo "$INSTALLED_EXTENSIONS" | grep -qi "^${ext}$"; then
            code --install-extension "$ext" 2>/dev/null || true
        fi
    done < "$EXTENSIONS_FILE"
fi

# ============================================
# SSH Key Setup
# ============================================
if ask "Set up SSH key and GitHub authentication?"; then
    SSH_KEY="$HOME/.ssh/id_ed25519"
    HOST="$(get_hostname)"

    if [[ ! -f "$SSH_KEY" ]]; then
        msg ""
        printf "Enter your email for the SSH key: "
        read -r email_address
        msg "Generating SSH key..."
        ssh-keygen -t ed25519 -C "$email_address" -N "" -f "$SSH_KEY"
        msg "SSH key generated at $SSH_KEY"
    else
        msg "SSH key already exists at $SSH_KEY"
    fi

    if command -v gh &>/dev/null; then
        PERSONAL_LOGGED_IN=false
        if gh auth status --hostname github.com 2>&1 | grep -q "jason-lieb"; then
            PERSONAL_LOGGED_IN=true
            gh auth switch --user jason-lieb 2>/dev/null || true
            PERSONAL_SCOPES="$(gh auth status --hostname github.com 2>&1 | grep "Token scopes" | head -1 || true)"
            if ! echo "$PERSONAL_SCOPES" | grep -q "admin:public_key" || ! echo "$PERSONAL_SCOPES" | grep -q "admin:ssh_signing_key"; then
                if ask "Refresh personal GitHub token scopes?"; then
                    msg "Refreshing personal GitHub token scopes..."
                    gh auth refresh -s admin:public_key,admin:ssh_signing_key || true
                fi
            fi
        else
            if ask "Log into personal GitHub (jason-lieb)?"; then
                msg "Logging into personal GitHub account (jason-lieb)..."
                gh auth login -p https -s admin:public_key,admin:ssh_signing_key || true
                if gh auth status 2>&1 | grep -q "jason-lieb"; then
                    PERSONAL_LOGGED_IN=true
                fi
            fi
        fi

        if [[ "$PERSONAL_LOGGED_IN" == true ]]; then
            gh auth switch --user jason-lieb 2>/dev/null || true
            if gh ssh-key list 2>/dev/null | grep -qF "$(cut -d' ' -f2 "$SSH_KEY.pub")"; then
                msg "SSH key already registered on GitHub"
            else
                if ask "Add SSH key to personal GitHub?"; then
                    msg "Adding SSH key to GitHub..."
                    gh ssh-key add "$SSH_KEY.pub" --title "$HOST"
                    msg "SSH key added to GitHub as '$HOST'"
                fi
            fi
        fi

        if ask "Log into work GitHub (Jason-Lieb_fnf)?"; then
            if gh auth status --hostname github.com 2>&1 | grep "account" | grep -v "jason-lieb" | grep -q "Logged in"; then
                msg "Work GitHub account (Jason-Lieb_fnf) already logged in"
                gh auth switch --user Jason-Lieb_fnf 2>/dev/null || true
            else
                msg "Logging into work GitHub account — sign in as Jason-Lieb_fnf (cincpro)..."
                gh auth login -p https -s read:packages || true
            fi
        fi
    fi

    CURRENT_REMOTE="$(git -C "$REPO_DIR" remote get-url origin 2>/dev/null || echo "")"
    if [[ "$CURRENT_REMOTE" == https://github.com/* ]]; then
        if ask "Switch repo remote to SSH?"; then
            if ssh -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
                SSH_REMOTE="${CURRENT_REMOTE/https:\/\/github.com\//git@github.com:}"
                msg "Switching repo remote to SSH..."
                git -C "$REPO_DIR" remote set-url origin "$SSH_REMOTE"
                msg "Remote updated: $SSH_REMOTE"
            else
                msg "SSH authentication to GitHub not working yet. Keeping HTTPS remote."
                msg "After adding your SSH key to GitHub, run:"
                msg "  git -C $REPO_DIR remote set-url origin ${CURRENT_REMOTE/https:\/\/github.com\//git@github.com:}"
            fi
        fi
    fi
else
    warn "Skipping SSH key and GitHub authentication setup."
fi

# ============================================
# Set Fish as Default Shell
# ============================================
if [[ -x "$FISH_PATH" ]]; then
    CURRENT_SHELL="$(get_current_shell)"
    if [[ "$CURRENT_SHELL" != *"fish"* ]]; then
        if ! grep -q "$FISH_PATH" /etc/shells 2>/dev/null; then
            msg "Adding fish to /etc/shells..."
            echo "$FISH_PATH" | sudo tee -a /etc/shells > /dev/null
        fi
        msg "Setting fish as default shell..."
        chsh -s "$FISH_PATH"
    fi
fi

msg ""
msg "=== Dotfiles Configuration Complete ==="
